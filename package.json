{
  "name": "stream-mind",
  "version": "1.0.0",
  "desktopName": "StreamMind",
  "description": "Local AI Container & Log Observer",
  "main": "dist/main/main.cjs",
  "type": "module",
  "author": {
    "email": "rsrabari8667@gmail.com",
    "name": "Raj Rabari"
  },
  "scripts": {
    "dev:react": "vite",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "watch:electron": "concurrently \"tsc -p tsconfig.main.json -w\" \"tsc -p tsconfig.preload.json -w\"",
    "start:electron": "wait-on tcp:5173 && electron . --no-sandbox",
    "dev": "rm -rf dist && npm run build:electron && concurrently -k \"npm run dev:react\" \"npm run watch:electron\" \"npm run start:electron\"",
    "build:react": "tsc -p tsconfig.renderer.json && vite build",
    "build": "npm run build:react && npm run build:electron",
    "build:prod": "rm -rf dist && npm run build && electron-builder"
  },
  "build": {
    "appId": "com.rajrabari.streammind",
    "productName": "StreamMind",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/streammind.png",
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/streammind.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/streammind.png"
    }
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@tailwindcss/vite": "^4.3.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
